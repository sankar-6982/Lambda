import boto3
import json
from botocore.exceptions import ClientError

s3 = boto3.client('s3')
sns = boto3.client('sns')

SNS_TOPIC_ARN = "arn:aws:sns:ap-south-1:386315605351:S3bucket-tpoic"

def is_bucket_public(bucket_name):
    public = False
    reasons = []


    try:
        acl = s3.get_bucket_acl(Bucket=bucket_name)

        for grant in acl['Grants']:
            grantee = grant.get('Grantee', {})
            permission = grant.get('Permission')

            # Public via ACL (AllUsers or AuthenticatedUsers)
            if grantee.get('URI') in [
                "http://acs.amazonaws.com/groups/global/AllUsers",
                "http://acs.amazonaws.com/groups/global/AuthenticatedUsers"
            ]:
                public = True
                reasons.append(f"ACL allows {permission} to public users")

    except ClientError as e:
        print(f"ACL check failed for {bucket_name}: {e}")


    try:
        policy = s3.get_bucket_policy(Bucket=bucket_name)
        policy_json = json.loads(policy['Policy'])

        for statement in policy_json.get('Statement', []):

            if statement.get('Effect') == 'Allow':
                principal = statement.get('Principal')

                # Detect all possible public principal formats
                if principal == "*" \
                        or principal == {"AWS": "*"} \
                        or (isinstance(principal, dict) and principal.get("AWS") == "*"):

                    public = True
                    reasons.append("Bucket policy allows public access")

    except ClientError as e:
        error_code = e.response['Error']['Code']

        if error_code == 'NoSuchBucketPolicy':
            pass
        elif error_code == 'AccessDenied':
            print(f"Access denied for bucket policy: {bucket_name}")
        else:
            print(f"Policy check failed for {bucket_name}: {e}")


    try:
        pab = s3.get_public_access_block(Bucket=bucket_name)
        config = pab['PublicAccessBlockConfiguration']

        # If public access block is disabled → bucket can be public
        if not config['BlockPublicAcls'] or not config['BlockPublicPolicy']:
            public = True
            reasons.append("Public access block is disabled")

    except ClientError as e:
        print(f"PAB check failed for {bucket_name}: {e}")

    return public, reasons


def lambda_handler(event, context):
    try:
        buckets = s3.list_buckets()

        for bucket in buckets['Buckets']:
            bucket_name = bucket['Name']
            print(f"Checking bucket: {bucket_name}")

            is_public, reasons = is_bucket_public(bucket_name)

            # DEBUG LINE (you can remove later)
            print(f"Public: {is_public}, Reasons: {reasons}")

            if is_public:
                message = f"Bucket {bucket_name} is PUBLIC.\nReasons:\n" + "\n".join(reasons)

                print(message)

                sns.publish(
                    TopicArn=SNS_TOPIC_ARN,
                    Subject="S3 Public Bucket Alert",
                    Message=message
                )

        return {
            'statusCode': 200,
            'body': 'Scan completed'
        }

    except Exception as e:
        print(f"Error in lambda_handler: {e}")
        raise e
